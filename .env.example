# Minimal optional overrides.
#
# Docker compose files already provide sane defaults using
# ${VARIABLE_NAME:-default} for local boot.
#
# Only override values here when you need custom behavior.

# Strongly recommended for production (change this):
JWT_SECRET=change-me-super-secret

# Single-user deployment credentials (optional override):
ADMIN_USERNAME=admin
# htpasswd -bnBC 12 "" YOUR_PASSWORD | tr -d ':\n' | sed 's/\$/\$\$/g'
ADMIN_PASSWORD_BCRYPT=CHANGE_ME_TO_A_BCRYPT_HASHED_PASSWORD

# Optional examples:
# TZ=Europe/Berlin
# OPENCROW_VERSION=latest

# URL the BROWSER uses to reach the Go backend API.
# Set this to your LAN IP or public domain when accessing from other devices.
# Default: http://localhost:8080
# API_BASE_URL=http://192.168.1.x:8080

# Voice transcription via go-whisper sidecar (optional):
# Omit or leave empty to disable voice transcription.
# WHISPER_ENDPOINT=http://whisper:8081
# WHISPER_MODEL=ggml-base

# Allowed CORS and WebSocket origins (comma-separated).
# Use "*" to permit all origins (default, suitable for LAN/home-server use).
# For internet-facing deployments restrict to your actual domain(s):
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Maximum number of concurrent device sessions per user.
# 0 = unlimited (default). Useful to prevent session flooding.
# MAX_SESSIONS_PER_USER=10
MAX_SESSIONS_PER_USER=1
