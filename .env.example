# API
API_PORT=8080
API_HOST=0.0.0.0
APP_ENV=development
APP_BASE_URL=http://localhost:3000

# Auth
JWT_ISSUER=openCrow
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h
JWT_SECRET=change-me-super-secret

# Postgres
POSTGRES_DB=opencrow
POSTGRES_USER=opencrow
POSTGRES_PASSWORD=opencrow
POSTGRES_PORT=5432
DATABASE_URL=postgres://opencrow:opencrow@postgres:5432/opencrow?sslmode=disable

# Redis
REDIS_PORT=6379
REDIS_ADDR=redis:6379

# State persistence
STATE_DIR=/data
CONFIG_FILE_PATH=/data/config.json

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Single-user deployment auth (required)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_BCRYPT=$2b$12$ijtzIHamaFvTGVjvd0IvtuhIIhMBQkwaI2aw6ZrIZHrPC1PUdBW9m

# Server shell command runner
SERVER_SHELL_ENABLED=false
SERVER_SHELL_TIMEOUT=8s

# Timezone (used by server for local time tools, e.g. Europe/Amsterdam)
TZ=UTC
